@page "/TeacherSession"
@inject SessionServices SessionServices
@inject UserServices UserServices
@inject LiveSessionServices LiveSessionServices
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Teacher</PageTitle>

<div class="teacherSession">
    <div class="teacherSessionContent">
        <AuthorizeView>
            <Authorized>
                @if (_isLoading || !_isInSession)
                {
                    <div class="inactiveSessionContainer">
                        <img class="logo" src="images/smarticipate-logo.png"/></div>
                    <h2>Checking for active session...</h2>
                }
                else
                {
                    <div class="activeSessionContainer">
                        <div class="sessionInfo actionBar">
                            <MudIconButton Class="backIcon" Color="Color.Dark"
                                           Icon="@Icons.Material.Outlined.ArrowBack" Size="Size.Small"
                                           aria-label="Back to dashboard" OnClick="GoToDashboard"/>
                            <div class="sessionHeading">
                                <h2 class="activeSessionTitle">@(string.IsNullOrWhiteSpace(_sessionName) ? _sessionCode : _sessionName)</h2>
                            </div>
                            <span class="actionBarSep"></span>
                            <ShareButton SessionCode="@_sessionCode" SessionName="@_sessionName"/>
                            <button class="stopSessionBtn" aria-label="Stop session" @onclick="EndSession">
                                <MudIcon Icon="@Icons.Material.Outlined.StopCircle" Size="Size.Small"/>
                                Stop
                            </button>
                        </div>
                    </div>
                    <div class="studentCount">
                        <MudIcon Icon="@Icons.Material.Outlined.PeopleOutline" Color="Color.Dark" Size="Size.Large"/>
                        @StudentCount
                    </div>
                    
                    <TeacherFeedbackOverlay SessionCode="@_sessionCode"></TeacherFeedbackOverlay>
                }
            </Authorized>
            <NotAuthorized>
                <h2 class="signInPrompt">You need to
                    <a id="signIn" href="/login">sign in</a>
                    to access this page
                </h2>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "mode")]
    public string? Mode { get; set; }

    //SESSION
    private bool _isLoading = true;
    private bool _isInSession;
    private string _sessionCode = string.Empty;
    private string? _sessionName;

    //STUDENT COUNT
    private int _studentCount = 0;

    private int StudentCount
    {
        get => _studentCount;
        set
        {
            if (_studentCount != value)
            {
                _studentCount = value;
                StateHasChanged();
            }
        }
    }

    //HEARTBEAT
    private Timer? _heartbeatTimer;
    private readonly int _heartbeatInterval = 15000;

    protected override async Task OnInitializedAsync()
    {
        await LiveSessionServices.InitializeConnection();
        LiveSessionServices.OnStudentCountChanged -= HandleStudentCountChanged;
        LiveSessionServices.OnStudentCountChanged += HandleStudentCountChanged;

        await LoadActiveSession();

        // The dashboard is home base: with no active session there is nothing to show here, so send the teacher back instead of rendering a dead screen.
        if (!_isInSession)
        {
            Navigation.NavigateTo("/Dashboard");
            return;
        }

        await LiveSessionServices.JoinSession(_sessionCode);
        await LiveSessionServices.RegisterAsTeacher(_sessionCode);

        // "Start fresh" from the dashboard zeroes feedback and clears the queue; resume keeps both.
        if (Mode == "reset")
        {
            await LiveSessionServices.ResetFeedback(_sessionCode);
            await LiveSessionServices.ClearQuestions(_sessionCode);
        }

        // `mode` is a one-shot entry instruction; strip it so a refresh does not re-run this.
        if (!string.IsNullOrEmpty(Mode))
        {
            Navigation.NavigateTo("/TeacherSession", replace: true);
        }

        StartHeartbeatTimer();
    }

    private async Task LoadActiveSession()
    {
        try
        {
            var userId = await UserServices.GetAuthenticatedUser();
            if (!string.IsNullOrEmpty(userId))
            {
                var activeSession = await SessionServices.GetActiveSessionAsync(userId);
                if (activeSession is not null)
                {
                    _isInSession = true;
                    _sessionCode = activeSession.SessionCode;
                    _sessionName = activeSession.Name;

                    await LiveSessionServices.JoinSession(_sessionCode);
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading active session: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task EndSession()
    {
        try
        {
            if (!string.IsNullOrEmpty(_sessionCode))
            {
                // Stop is server-authoritative: the endpoint ends the session AND releases live state (notifies students, clears in-memory state). We just leave the SignalR group here.
                var success = await SessionServices.UpdateSessionAsync(_sessionCode);
                if (!success)
                {
                    Console.WriteLine("Error updating session");
                }

                await LiveSessionServices.LeaveSession();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception when stopping session: {ex.Message}");
        }
        finally
        {
            _isInSession = false;
            _sessionCode = string.Empty;
            Navigation.NavigateTo("/Dashboard");
        }
    }

    public async ValueTask DisposeAsync()
    {
        LiveSessionServices.OnStudentCountChanged -= HandleStudentCountChanged;

        _heartbeatTimer?.Dispose();
        _heartbeatTimer = null;

        if (_isInSession && !string.IsNullOrEmpty(_sessionCode))
        {
            try
            {
                // Only leave the SignalR group on dispose. Do NOT end the session here: a reload/navigation must keep the session alive (ending is the Stop button only).
                await LiveSessionServices.LeaveSession();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error leaving session: {ex.Message}");
            }
        }
    }

    private void StartHeartbeatTimer()
    {
        _heartbeatTimer = new Timer(
            async _ =>
            {
                if (_isInSession && LiveSessionServices.IsConnected)
                {
                    try
                    {
                        await LiveSessionServices.SendHeartbeat();
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"Heartbeat error: {ex.Message}");
                    }
                }
            }, null, _heartbeatInterval, _heartbeatInterval
        );
    }

    private void GoToDashboard() => Navigation.NavigateTo("/Dashboard");

    private void HandleStudentCountChanged(int count)
    {
        StudentCount = count;
        InvokeAsync(StateHasChanged);
    }

}