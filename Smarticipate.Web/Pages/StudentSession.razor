@page "/StudentSession"
@inject NavigationManager Navigation
@inject LiveSessionServices LiveSessionServices
@inject SessionServices SessionServices
@inject ResponseServices ResponseServices
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Student</PageTitle>

<div class="studentSession">
    <div class="studentSessionContent">
        @if (_isInSession && !string.IsNullOrEmpty(_sessionCode))
        {
            <StudentFeedbackOverlay SessionCode="@_sessionCode"/>
        }

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Dark" Size="Size.Large"/>
        }
        else if (_isInSession && ActiveQuestionId.HasValue)
        {
            <div class="activeSessionContainer">
                <div class="sessionInfo actionBar">
                    <div class="sessionHeading">
                        <h2 class="activeSessionTitle">@(string.IsNullOrWhiteSpace(_sessionName) ? _sessionCode : _sessionName)</h2>
                        @if (!string.IsNullOrWhiteSpace(_sessionName))
                        {
                            @CodePill
                        }
                    </div>
                    <span class="actionBarSep"></span>
                    <button class="leaveSessionBtn" aria-label="Leave session" @onclick="LeaveSession">
                        <MudIcon Icon="@Icons.Material.Outlined.ExitToApp" Size="Size.Small"/>
                        Leave
                    </button>
                </div>
            </div>
            <div class="questionContainer">
                <h1>Choose your response (Question #@CurrentQuestionNumber)</h1>
                <div class="responseOptions">
                    <button id="tooSlow" class="responseBtn tooSlow"
                            @onclick="() => SubmitResponse(ResponseOption.TooSlow)"
                            disabled="@_hasAnswered">
                        <img class="responseBtnImage" src="images/sloth.svg" alt="Too slow - sloth"/>
                        <p class="optionText">We're moving slower than a herd of sloths stampeding through peanut
                            butter! Let's pick it up!</p>
                    </button>
                    <button id="perfect" class="responseBtn perfect"
                            @onclick="() => SubmitResponse(ResponseOption.Perfect)"
                            disabled="@_hasAnswered">
                        <img class="responseBtnImage" src="images/metronome.svg" alt="Perfect - metronome"/>
                        <p class="optionText">I’m in a groove, right now!</p>
                    </button>
                    <button id="tooFast" class="responseBtn tooFast"
                            @onclick="() => SubmitResponse(ResponseOption.TooFast)"
                            disabled="@_hasAnswered">
                        <img class="responseBtnImage" src="images/cheetah.svg"
                             alt="Too fast - cheetah"/>
                        <p class="optionText">Even cheetahs need to pace themselves. Let's take a breather.</p>
                    </button>

                </div>
                <div class="countdown">
                    <MudProgressCircular Class="progressCircle"
                                         Color="@(_countdownTime < 20 ? (_countdownTime < 10 ? Color.Error : Color.Tertiary) : Color.Dark)"
                                         Style="width: 150px; height: 150px;" Indeterminate="true"/>
                    <h1 class="countDownRest">@_countdownDisplay</h1>
                </div>
            </div>
        }
        else if (_isInSession || _hasAnswered)
        {
            <div class="activeSessionContainer">
                <div class="sessionInfo actionBar">
                    <div class="sessionHeading">
                        <h2 class="activeSessionTitle">@(string.IsNullOrWhiteSpace(_sessionName) ? _sessionCode : _sessionName)</h2>
                        @if (!string.IsNullOrWhiteSpace(_sessionName))
                        {
                            @CodePill
                        }
                    </div>
                    <span class="actionBarSep"></span>
                    <button class="leaveSessionBtn" aria-label="Leave session" @onclick="LeaveSession">
                        <MudIcon Icon="@Icons.Material.Outlined.ExitToApp" Size="Size.Small"/>
                        Leave
                    </button>
                </div>
            </div>
            <div class="waitingContainer">
                @if (_hasAnswered)
                {
                    <h3>Thank you for your answer!</h3>
                }
                <h1>Waiting for next question...</h1>
                <img class="logo" src="images/smarticipate-logo.png"/>

            </div>
        }
        else if (_sessionEnded)
        {
            <div class="sessionEndedContainer">
                <h1>Session has ended</h1>
                <h3 class="participation">Thank you for participating!</h3>
                <button class="submitBtn" @onclick="ResetSession">Join session</button>
            </div>
        }
        else if (_linkSessionInactive)
        {
            <div class="sessionEndedContainer">
                <h1>This session isn't active right now</h1>
                <h3 class="participation">Ask your teacher to start it, then try the link again, or enter a code below.</h3>
                <button class="submitBtn" @onclick="DismissInactiveLink">Enter a code</button>
            </div>
        }
        else
        {
            <div class="joinSessionContainer">
                <div class="form">
                    <div class="formField joinForm">
                        <label class="joinTitle">Enter session code</label>
                        <input type="text" id="inputText" @bind="_sessionCode" @bind:event="oninput"/>
                        <button class="submitBtn" @onclick="JoinSession">Join</button>
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <p class="errorMessage">@_errorMessage</p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter, SupplyParameterFromQuery(Name = "code")]
    public string? CodeFromQuery { get; set; }

    private bool _isLoading = true;
    private bool _isInSession = false;
    private bool _sessionEnded = false;
    private bool _linkSessionInactive = false;
    private bool _hasAnswered = false;
    private string _sessionCode = string.Empty;
    private string? _sessionName;
    private int? _activeQuestionId;
    private int _currentQuestionNumber;
    private int _countdownTime = 0;
    private string _countdownDisplay = "00:00";
    private string _errorMessage = string.Empty;

    private RenderFragment CodePill => @<button type="button" class="activeSessionCode codeCopyable" title="Copy session code" @onclick="CopyCode">@_sessionCode<MudIcon Icon="@Icons.Material.Outlined.ContentCopy" Style="font-size:1.05rem;margin-left:.25rem;color:var(--dark);"/></button>;

    private readonly RenderFragment _codeCopied = @<text>Session <span class="copyEmphasis">code</span> copied to clipboard</text>;

    private async Task CopyCode()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _sessionCode);
            Snackbar.Add(_codeCopied, Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error copying code: {ex.Message}");
            Snackbar.Add("Couldn't copy", Severity.Error);
        }
    }

    private int? ActiveQuestionId
    {
        get => _activeQuestionId;
        set
        {
            if (_activeQuestionId != value)
            {
                _activeQuestionId = value;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    private int CurrentQuestionNumber
    {
        get => _currentQuestionNumber;
        set
        {
            if (_currentQuestionNumber != value)
            {
                _currentQuestionNumber = value;
                InvokeAsync(StateHasChanged);
            }
        }
    }

    private int CountdownTime
    {
        get => _countdownTime;
        set
        {
            if (_countdownTime != value)
            {
                _countdownTime = value;
                _countdownDisplay = TimeSpan.FromSeconds(value).ToString(@"mm\:ss");
                InvokeAsync(StateHasChanged);
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        try
        {
            // Register handlers once the hub is actually connected (waits for the connected
            // state instead of a fixed delay).
            if (await LiveSessionServices.EnsureConnectedAsync())
            {
                LiveSessionServices.OnQuestionStarted -= HandleQuestionStarted;
                LiveSessionServices.OnQuestionStarted += HandleQuestionStarted;

                LiveSessionServices.OnQuestionStopped -= HandleQuestionStopped;
                LiveSessionServices.OnQuestionStopped += HandleQuestionStopped;

                LiveSessionServices.OnTimerUpdated -= HandleTimerUpdated;
                LiveSessionServices.OnTimerUpdated += HandleTimerUpdated;

                LiveSessionServices.OnSessionEnded -= HandleSessionEnded;
                LiveSessionServices.OnSessionEnded += HandleSessionEnded;

                LiveSessionServices.OnTeacherDisconnected -= HandleTeacherDisconnected;
                LiveSessionServices.OnTeacherDisconnected += HandleTeacherDisconnected;

                // A link takes precedence over the saved session so pasting one in the same tab switches sessions; without one, restore the tab's session across a refresh.
                if (!string.IsNullOrWhiteSpace(CodeFromQuery))
                {
                    await TryJoinFromLinkAsync(CodeFromQuery);
                    // The code is a one-shot entry instruction; strip it so it can't go stale or re-fire on a later refresh or leave.
                    Navigation.NavigateTo("/StudentSession", replace: true);
                }
                else
                {
                    await TryRestoreSessionAsync();
                }
            }

            // Start the heartbeat regardless of connection state; the callback guards on
            // (_isInSession && IsConnected), so it only sends once the student is in a session.
            StartHeartbeatTimer();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error initializing student session: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void HandleQuestionStarted(int questionId, int duration, int remainingTime)
    {
        InvokeAsync(async () =>
        {
            ActiveQuestionId = null;
            StateHasChanged();

            ActiveQuestionId = questionId;

            if (!string.IsNullOrEmpty(_sessionCode))
            {
                var sessionResponse = await SessionServices.GetSessionStatusByCodeAsync(_sessionCode);
                var question = sessionResponse?.Questions.FirstOrDefault(q => q.Id == questionId);
                CurrentQuestionNumber = question?.QuestionNumber ?? 0;
            }

            _hasAnswered = false;
            CountdownTime = remainingTime;
            StateHasChanged();
        });
    }

    private void HandleQuestionStopped()
    {
        InvokeAsync(() =>
        {
            ActiveQuestionId = null;
            _hasAnswered = false;
            _countdownDisplay = "00:00";
            StateHasChanged();
        });
    }

    private void HandleTimerUpdated(int remainingTime)
    {
        InvokeAsync(() =>
        {
            CountdownTime = remainingTime;

            if (remainingTime <= 0 && ActiveQuestionId.HasValue)
            {
                ActiveQuestionId = null;
            }

            StateHasChanged();
        });
    }

    private void HandleSessionEnded()
    {
        InvokeAsync(async () =>
        {
            _isInSession = false;
            _sessionEnded = true;
            ActiveQuestionId = null;
            await ClearSavedSessionAsync();
            StateHasChanged();
        });
    }

    private void HandleTeacherDisconnected()
    {
        InvokeAsync(async () =>
        {
            _isInSession = false;
            _sessionEnded = true;
            _activeQuestionId = null;
            await ClearSavedSessionAsync();
            StateHasChanged();
        });
    }

    private async Task<bool> JoinActiveSessionAsync(string code, SessionServices.StudentSessionResponse session)
    {
        await LiveSessionServices.JoinSession(code);
        await LiveSessionServices.RegisterAsStudent(code);

        if (!LiveSessionServices.IsConnected)
        {
            return false;
        }

        _sessionCode = code;
        _sessionName = session.Name;
        _isInSession = true;
        _sessionEnded = false;
        await SaveSessionAsync(code);
        return true;
    }

    private async Task JoinSession()
    {
        if (string.IsNullOrWhiteSpace(_sessionCode))
        {
            _errorMessage = "Please enter a session code";
            return;
        }

        _errorMessage = string.Empty;

        try
        {
            var session = await SessionServices.GetSessionStatusByCodeAsync(_sessionCode);

            if (session is not null && session.IsActive)
            {
                _isLoading = true;
                if (!await JoinActiveSessionAsync(_sessionCode, session))
                {
                    _errorMessage = "Connection error. Please try again.";
                }
            }
            else
            {
                _errorMessage = "No active session found with that code.";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error joining session: {ex.Message}");
            _errorMessage = "Error joining session. Please try again.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LeaveSession()
    {
        if (_isInSession && !string.IsNullOrEmpty(_sessionCode))
        {
            try
            {
                await LiveSessionServices.LeaveAsStudent(_sessionCode);
                await LiveSessionServices.LeaveSession();
                ResetSession();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error leaving session: {ex.Message}");
            }
        }
    }

    private async Task ResetSession()
    {
        _sessionCode = string.Empty;
        _sessionName = null;
        _isInSession = false;
        _sessionEnded = false;
        ActiveQuestionId = null;
        await ClearSavedSessionAsync();
    }

    private const string SessionStorageKey = "smarticipate.student.sessionCode";

    private async Task TryRestoreSessionAsync()
    {
        try
        {
            var savedCode = await JS.InvokeAsync<string>("sessionStorage.getItem", SessionStorageKey);
            if (string.IsNullOrWhiteSpace(savedCode))
            {
                return;
            }

            var session = await SessionServices.GetSessionStatusByCodeAsync(savedCode);
            if (session is not null && session.IsActive)
            {
                await JoinActiveSessionAsync(savedCode, session);
            }
            else
            {
                await ClearSavedSessionAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error restoring session: {ex.Message}");
        }
    }

    private async Task TryJoinFromLinkAsync(string code)
    {
        _sessionCode = code;
        try
        {
            var session = await SessionServices.GetSessionStatusByCodeAsync(code);
            if (session is not null && session.IsActive && await JoinActiveSessionAsync(code, session))
            {
                return;
            }

            _linkSessionInactive = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error joining from link: {ex.Message}");
            _linkSessionInactive = true;
        }
    }

    private void DismissInactiveLink()
    {
        _linkSessionInactive = false;
        _sessionCode = string.Empty;
    }

    private async Task SaveSessionAsync(string code)
    {
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", SessionStorageKey, code);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving session: {ex.Message}");
        }
    }

    private async Task ClearSavedSessionAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.removeItem", SessionStorageKey);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error clearing saved session: {ex.Message}");
        }
    }

    private async Task SubmitResponse(ResponseOption option)
    {
        if (ActiveQuestionId.HasValue && !_hasAnswered)
        {
            await ResponseServices.CreateResponseAsync(ActiveQuestionId.Value, option);
            _hasAnswered = true;
            ActiveQuestionId = null;
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        LiveSessionServices.OnQuestionStarted -= HandleQuestionStarted;
        LiveSessionServices.OnQuestionStopped -= HandleQuestionStopped;
        LiveSessionServices.OnTimerUpdated -= HandleTimerUpdated;
        LiveSessionServices.OnSessionEnded -= HandleSessionEnded;
        LiveSessionServices.OnTeacherDisconnected -= HandleTeacherDisconnected;

        if (_isInSession)
        {
            await LiveSessionServices.LeaveSession();
        }

        _heartbeatTimer?.Dispose();
        _heartbeatTimer = null;
    }

    private Timer? _heartbeatTimer;

    private void StartHeartbeatTimer()
    {
        _heartbeatTimer = new Timer(async _ =>
        {
            if (_isInSession && LiveSessionServices.IsConnected)
            {
                try
                {
                    await LiveSessionServices.SendHeartbeat();
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Heartbeat error: {ex.Message}");
                }
            }
        }, null, 15000, 15000);
    }

}