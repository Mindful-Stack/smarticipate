@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudTooltip Text="@Tooltip">
    <MudIconButton Class="@Class"
                   Color="Color.Dark"
                   Icon="@Icon"
                   Size="@Size"
                   aria-label="@Tooltip"
                   OnClick="Copy"/>
</MudTooltip>

@code {
    [Parameter, EditorRequired] public string Text { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.ContentCopy;
    [Parameter] public string Tooltip { get; set; } = "Copy";
    [Parameter] public RenderFragment? SuccessMessage { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public Size Size { get; set; } = Size.Small;

    private async Task Copy()
    {
        if (string.IsNullOrEmpty(Text)) return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Text);
            Snackbar.Add(SuccessMessage ?? DefaultMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error copying to clipboard: {ex.Message}");
            Snackbar.Add("Couldn't copy", Severity.Error);
        }
    }

    private readonly RenderFragment DefaultMessage = builder => builder.AddContent(0, "Copied to clipboard");
}
